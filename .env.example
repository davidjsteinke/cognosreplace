# Copy to .env and fill in values for your environment

# Set to "mock" to use the local mock server, or "production" for real Cognos
COGNOS_MODE=mock

# Mock server base URL (used when COGNOS_MODE=mock)
COGNOS_MOCK_URL=https://localhost:3001

# Production Cognos server URL (used when COGNOS_MODE=production)
COGNOS_BASE_URL=https://cognos.your-college.edu

# Cognos namespace (typically the AD namespace configured in Cognos)
COGNOS_NAMESPACE=YourADNamespace

# Add-in host server port
SERVER_PORT=3000

# Session secret — replace with a long random string
SESSION_SECRET=change-this-to-a-random-secret-string

# SSL certificate paths (required for HTTPS)
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key

# Kerberos service principal name for the Cognos server
# Format: HTTP/hostname@REALM
COGNOS_SPN=HTTP/cognos.your-college.edu@YOUR-COLLEGE.EDU

# AD Domain for Kerberos
AD_DOMAIN=YOUR-COLLEGE.EDU
